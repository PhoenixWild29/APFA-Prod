# APFA-Prod .env.example
# Copy to .env and fill in production values.
# Reference: app/config.py Settings class

# MinIO / Object Storage (docker: http://minio:9000)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# AWS
AWS_REGION=us-east-1

# API Security
API_KEY=change-me-super-secret-api-key

# JWT Auth
JWT_SECRET=change-me-super-secret-jwt-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CSRF
CSRF_SECRET=change-me-csrf-secret
CSRF_TOKEN_EXPIRE_HOURS=24

# Cookies
COOKIE_DOMAIN=apfa.secureai.dev
COOKIE_SECURE=true
COOKIE_SAMESITE=strict

# AI/ML
LLM_MODEL_NAME=meta-llama/Llama-3-8b-hf
EMBEDDER_MODEL=all-MiniLM-L6-v2
DELTA_TABLE_PATH=s3a://customer-data-lakehouse/customers

# Logging
LOG_LEVEL=INFO
DEBUG=false

# Cognito (optional)
COGNITO_USER_POOL_ID=us-east-1_xxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_DOMAIN=https://your-domain.auth.us-east-1.amazoncognito.com

# Email (optional)
EMAIL_FROM=noreply@apfa.secureai.dev
EMAIL_VERIFICATION_URL=https://apfa.secureai.dev/verify

# Document Upload
S3_BUCKET_NAME=apfa-documents
ALLOWED_DOCUMENT_TYPES='["application/pdf","application/msword","application/vnd.openxmlformats-officedocument.wordprocessingml.document","text/plain"]'
MAX_FILE_SIZE_MB=50

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Database (docker default)
DATABASE_URL=postgresql://postgres:password@postgres:5432/apfa