# Prevent large/sensitive files from being included in the Docker build
# context. The image should contain only what's needed at runtime.
.git
.github
node_modules
dist
.env
*.md
*.bat
*.cmd
*.ps1
docs/
deploy/
infra/
monitoring/prometheus.yml
monitoring/alerts.yml
monitoring/grafana-dashboards/
Screenshot*
jest.config.cjs
index.html
